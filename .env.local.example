# ── FastAPI backend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Chatbot: Groq (cloud, free) ────────────────────────────────────────────
# Get a free key at https://console.groq.com — no credit card needed
# When set, Groq is used automatically (works on Vercel/Netlify)
# When not set, falls back to local Ollama
GROQ_API_KEY=

# Optional: override the default Groq model (default: llama-3.1-8b-instant)
# Other options: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
# GROQ_MODEL=llama-3.1-8b-instant

# ── Chatbot: Ollama (local dev) ────────────────────────────────────────────
# Only used when GROQ_API_KEY is not set
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
